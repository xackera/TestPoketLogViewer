<Window x:Class="TestPoketLogViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TestPoketLogViewer.ViewModels"
        Title="Poker Log Viewer" Height="500" Width="900"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Переключатель языка -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Orientation="Horizontal" Margin="0,-5,0,5">
            <Button Content="RU" Command="{Binding SwitchLanguageCommand}" CommandParameter="ru" Padding="5,0" Width="30" Margin="0,0,5,0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Foreground" Value="Gray"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRuSelected}" Value="True">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="EN" Command="{Binding SwitchLanguageCommand}" CommandParameter="en" Padding="5,0" Width="30" Background="Transparent" BorderThickness="0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Foreground" Value="Gray"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEnSelected}" Value="True">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Верхняя панель: Выбор папки -->
        <Grid Grid.Row="0" Margin="0,20,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Text="{DynamicResource LblFolder}" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Grid.Column="1" Text="{Binding SelectedDirectory, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Margin="0,0,10,0" IsEnabled="{Binding IsNotScanning}"/>
            <Button Grid.Column="2" Content="{DynamicResource BtnBrowse}" Command="{Binding SelectFolderCommand}" Padding="10,5" Margin="0,0,10,0" IsEnabled="{Binding IsNotScanning}"/>
            <Button Grid.Column="3" Content="{DynamicResource BtnStartScan}" Command="{Binding StartScanCommand}" Padding="10,5"/>
        </Grid>

        <!-- Основная область: поиск и 3 панели -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Строка поиска -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{DynamicResource LblSearch}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая панель: TableNames -->
                <GroupBox Header="{DynamicResource TitleTables}" Grid.Column="0" Margin="0,0,5,0">
                    <ListBox ItemsSource="{Binding TableNamesView}" SelectedItem="{Binding SelectedTableName}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>

                <!-- Средняя панель: HandIDs -->
                <GroupBox Header="{DynamicResource TitleHands}" Grid.Column="1" Margin="5,0,5,0">
                    <Grid>
                        <TextBlock Text="{DynamicResource SelectTable}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTableName}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ListBox ItemsSource="{Binding HandIdsView}" SelectedItem="{Binding SelectedHandId}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </GroupBox>

            <!-- Правая панель: Детали -->
            <GroupBox Header="{DynamicResource TitleDetails}" Grid.Column="2" Margin="5,0,0,0">
                <Grid>
                    <!-- Placeholder -->
                    <TextBlock Text="{DynamicResource SelectHand}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedHandDetails}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Контент -->
                    <StackPanel Margin="10">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedHandDetails}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="{DynamicResource LblPlayers}" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ItemsControl ItemsSource="{Binding SelectedHandDetails.Players}" Margin="10,0,0,15">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{DynamicResource LblWinners}" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ItemsControl ItemsSource="{Binding SelectedHandDetails.Winners}" Margin="10,0,0,15">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="Green" FontWeight="SemiBold"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{DynamicResource LblAmount}" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding SelectedHandDetails.WinAmount}" Margin="10,0,0,0" FontSize="16"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>
        </Grid>

        <!-- Статус бар -->
        <StatusBar Grid.Row="2" Margin="0,10,0,0" Background="Transparent">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
